{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "types": ["vitest/globals"],
        "strict": true,
        "exactOptionalPropertyTypes": false,
        "noUncheckedIndexedAccess": true,
        "declaration": true,
        "outDir": "dist",
        "esModuleInterop": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": false,
        "skipLibCheck": true
    },
    "include": ["src/**/*", "tests/**/*"]
}
