{
    "name": "@wzo/regex-diagram",
    "type": "module",
    "version": "0.0.0",
    "description": "Framework-agnostic regular-expression railroad-diagram visualizer (parse + layout + render)",
    "author": "nowo",
    "license": "MIT",
    "homepage": "https://nowo.github.io/regex",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nowo/regex.git",
        "directory": "packages/core"
    },
    "bugs": "https://github.com/nowo/regex/issues",
    "keywords": [
        "regex",
        "regexp",
        "railroad",
        "diagram",
        "visualize",
        "svg"
    ],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.mts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "README.zh.md",
        "dist",
        "src"
    ],
    "engines": {
        "node": ">=16.6"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "release": "changelogen --release --push"
    },
    "dependencies": {
        "@eslint-community/regexpp": "^4.12.1",
        "regexp-ast-analysis": "^0.7.1"
    },
    "devDependencies": {
        "changelogen": "^0.6.2",
        "tsdown": "^0.18.0",
        "typescript": "^5.9.3",
        "vitest": "^3.2.0"
    }
}
